{
  "name": "@opendatalabs/personal-server-ts-lite",
  "version": "0.0.1",
  "description": "Browser/WebView Personal Server Lite runtime boundary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vana-com/personal-server-ts.git",
    "directory": "packages/lite"
  },
  "homepage": "https://github.com/vana-com/personal-server-ts#readme",
  "bugs": {
    "url": "https://github.com/vana-com/personal-server-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "copy-tls": "mkdir -p dist/browser-tls-rustls && cp src/browser-tls-rustls/* dist/browser-tls-rustls/",
    "build": "tsc --build && npm run copy-tls"
  },
  "dependencies": {
    "@opendatalabs/personal-server-ts-core": "*",
    "@opendatalabs/vana-sdk": "3.0.1-canary.b068ac6",
    "node-forge": "^1.4.0",
    "viem": "^2.48.11"
  }
}
