{
  "name": "@opendatalabs/personal-server-ts-server",
  "version": "0.0.1",
  "description": "Hono HTTP server for the Vana Personal Server — routes, middleware, composition root",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vana-com/personal-server-ts.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/vana-com/personal-server-ts#readme",
  "bugs": {
    "url": "https://github.com/vana-com/personal-server-ts/issues"
  },
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./runtime": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "copy-ui": "mkdir -p dist/ui && cp src/ui/index.html dist/ui/index.html && cp ../lite/src/browser-tls-rustls/browser_tls_rustls_bg.wasm dist/ui/browser_tls_rustls_bg.wasm",
    "bundle-ui": "esbuild src/ui/ps-lite-debug.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/ui/ps-lite-debug.js",
    "build": "tsc --build && npm run copy-ui && npm run bundle-ui",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@opendatalabs/personal-server-ts-core": "*",
    "@opendatalabs/personal-server-ts-lite": "*",
    "@opendatalabs/vana-sdk": "3.6.0",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.12.18",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
