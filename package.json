{
  "name": "personal-server-ts",
  "private": true,
  "description": "TypeScript implementation of the Vana Data Portability Protocol's Personal Server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vana-com/personal-server-ts.git"
  },
  "homepage": "https://github.com/vana-com/personal-server-ts#readme",
  "bugs": {
    "url": "https://github.com/vana-com/personal-server-ts/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run build && node --env-file-if-exists=.env packages/server/dist/index.js",
    "dev": "tsc --build && tsx watch --env-file-if-exists=.env packages/server/src/index.ts",
    "build": "rm -rf packages/core/dist packages/core/tsconfig.tsbuildinfo && npm run build -w @opendatalabs/personal-server-ts-core && rm -rf packages/lite/dist packages/lite/tsconfig.tsbuildinfo && npm run build -w @opendatalabs/personal-server-ts-lite && rm -rf packages/server/dist packages/server/tsconfig.tsbuildinfo && npm run build -w @opendatalabs/personal-server-ts-server && rm -rf packages/cli/dist packages/cli/tsconfig.tsbuildinfo && npm run build -w @opendatalabs/personal-server-ts && tsc --build scripts",
    "clean": "tsc --build --clean && npm run clean:dist",
    "clean:dist": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint 'packages/*/src/**/*.ts'",
    "lint:eslint:fix": "eslint --fix 'packages/*/src/**/*.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "register-server": "tsx --env-file-if-exists=.env scripts/register-server.ts",
    "register-builder": "tsx --env-file-if-exists=.env scripts/register-builder.ts",
    "e2e:x402": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/e2e-x402-flow.ts",
    "e2e:x402-lite": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/e2e-x402-lite.ts",
    "e2e:sync": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/e2e-storage-sync.ts",
    "e2e:rebase": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/e2e-stale-version-rebase.ts",
    "e2e:register-pdf": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/e2e-register-pdf.ts",
    "e2e:read-scope": "tsx scripts/e2e-read-scope.ts",
    "e2e:read-scope-lite": "tsx scripts/e2e-read-scope-lite.ts",
    "validate": "npm run lint && npm run lint:eslint && npm run format:check && npm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@opendatalabs/vana-sdk": "3.11.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.6.1",
    "@types/node-forge": "^1.3.14",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "semantic-release": "^25.0.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
